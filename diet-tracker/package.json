{
  "name": "diet-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:android": "vue-tsc -b && vite build --mode android",
    "cap:sync": "npm run build:android && cap sync android",
    "cap:open": "cap open android",
    "android:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1",
    "android:update-manifest": "node scripts/create-update-manifest.mjs",
    "android:sdk": "powershell -ExecutionPolicy Bypass -File scripts/setup-android-sdk.ps1",
    "preview": "vite preview",
    "test": "vitest run",
    "audit:food-data": "node scripts/audit-food-data.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vueuse/core": "^14.3.0",
    "dayjs": "^1.11.21",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "unplugin-vue-components": "^32.1.0",
    "vant": "^4.9.24",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.8"
  }
}
